# Copy this file to .env.local and adjust the paths for your computer.
# Copia este archivo como .env.local y ajusta las rutas para tu computadora.

# Absolute path to the folder that contains this project.
# Ruta absoluta a la carpeta que contiene este proyecto.
PROJECT_DIR=/PATH/TO/proyectofinakl

# Absolute path to the parent workspace where shared helper scripts live.
# Ruta absoluta al workspace padre donde viven scripts auxiliares compartidos.
UASD_WORKSPACE_DIR=/PATH/TO/UASD

# PowerPoint template used to generate the final presentation.
# Plantilla PowerPoint usada para generar la presentacion final.
PPTX_TEMPLATE_PATH=/PATH/TO/template.pptx

# Helper Python script used by herramientas/generar_presentacion_final.py.
# Script Python auxiliar usado por herramientas/generar_presentacion_final.py.
PYTHON_PRESENTATION_BUILDER=/PATH/TO/build_presentacion_tarea51_inf8236.py

# Output presentation path.
# Ruta de salida de la presentacion.
PRESENTATION_OUTPUT_PATH=/PATH/TO/proyectofinakl/Presentacion_Final_Banco_Agricola_RD.pptx

# Markdown report input and PDF output.
# Entrada Markdown del informe y salida PDF.
REPORT_INPUT_PATH=/PATH/TO/proyectofinakl/documento/Proyecto_Final_Banco_Agricola.md
REPORT_OUTPUT_PATH=/PATH/TO/proyectofinakl/documento/Proyecto_Final_Banco_Agricola.pdf
